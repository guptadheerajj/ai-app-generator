generator client {
   provider     = "prisma-client"
   output       = "../generated/prisma"
   moduleFormat = "cjs"
}

datasource db {
   provider = "postgresql"
}

model Config {
   id        String   @id @default(cuid())
   name      String
   config    String
   createdAt DateTime @default(now())
   updatedAt DateTime @updatedAt
}
